generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProjectOwners {
  A        String
  B        String
  projects projects @relation(fields: [A], references: [id], onDelete: Cascade)

  @@unique([A, B], map: "_ProjectOwners_AB_unique")
  @@index([B], map: "_ProjectOwners_B_index")
  @@map("_ProjectOwners")
}

model accounts {
  id                                                      String          @id
  name                                                    String
  code                                                    String
  type                                                    AccountType
  description                                             String?
  balance                                                 Decimal         @default(0)
  organization_id                                         String
  created_at                                              DateTime        @default(now())
  updated_at                                              DateTime
  organizations                                           organizations   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  journal_lines_journal_lines_credit_account_idToaccounts journal_lines[] @relation("journal_lines_credit_account_idToaccounts")
  journal_lines_journal_lines_debit_account_idToaccounts  journal_lines[] @relation("journal_lines_debit_account_idToaccounts")

  @@unique([code, organization_id])
  @@index([organization_id])
}

model accounts_payable {
  id                        String                @id
  supplier_id               String?
  category_id               String?
  concepto                  String
  monto                     Decimal
  fecha_vencimiento         DateTime?
  status                    PaymentStatus         @default(PENDING)
  pagado                    Boolean               @default(false)
  autorizado                Boolean               @default(false)
  monto_pagado              Decimal               @default(0)
  monto_restante            Decimal?
  fecha_pago                DateTime?
  forma_pago                String?
  referencia_pago           String?
  factura_url               String?
  comprobante_url           String?
  notas                     String?
  legacy_account_payable_id Int?                  @unique
  organization_id           String
  created_at                DateTime              @default(now())
  updated_at                DateTime
  categories                categories?           @relation(fields: [category_id], references: [id])
  organizations             organizations         @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  suppliers                 suppliers?            @relation(fields: [supplier_id], references: [id])
  payment_complements       payment_complements[]

  @@index([category_id])
  @@index([fecha_pago])
  @@index([fecha_vencimiento])
  @@index([legacy_account_payable_id])
  @@index([organization_id])
  @@index([pagado])
  @@index([status])
  @@index([supplier_id])
}

model accounts_receivable {
  id                           String        @id
  project_id                   String
  client_id                    String?
  concepto                     String
  monto                        Decimal
  fecha_vencimiento            DateTime?
  status                       PaymentStatus @default(PENDING)
  monto_pagado                 Decimal       @default(0)
  monto_restante               Decimal
  notas                        String?
  legacy_account_receivable_id Int?          @unique
  organization_id              String
  created_at                   DateTime      @default(now())
  updated_at                   DateTime
  clients                      clients?      @relation(fields: [client_id], references: [id])
  organizations                organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  projects                     projects      @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([client_id])
  @@index([fecha_vencimiento])
  @@index([legacy_account_receivable_id])
  @@index([organization_id])
  @@index([project_id])
  @@index([status])
}

model api_keys {
  id              String        @id
  name            String
  key             String        @unique
  prefix          String
  user_id         String
  organization_id String
  scopes          String[]
  last_used_at    DateTime?
  created_at      DateTime      @default(now())
  updated_at      DateTime
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  users           users         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([prefix])
  @@index([user_id])
}

model attachments {
  id              String   @id
  url             String
  filename        String
  mime_type       String
  size            Int
  task_id         String?
  organization_id String
  created_at      DateTime @default(now())
  tasks           tasks?   @relation(fields: [task_id], references: [id])

  @@index([organization_id])
  @@index([task_id])
}

model audit_logs {
  id         String   @id
  user_id    String?
  action     String
  resource   String
  ip_address String?
  user_agent String?
  details    Json?
  status     String   @default("SUCCESS")
  created_at DateTime @default(now())
  user       users?   @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([created_at])
  @@index([resource])
  @@index([user_id])
}

model categories {
  id                 String             @id
  nombre             String
  descripcion        String?
  color              String?
  is_active          Boolean            @default(true)
  legacy_category_id Int?               @unique
  organization_id    String
  created_at         DateTime           @default(now())
  updated_at         DateTime
  accounts_payable   accounts_payable[]
  organizations      organizations      @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([is_active])
  @@index([legacy_category_id])
  @@index([organization_id])
}

model clients {
  id                  String                @id
  run_cliente         String?
  nombre              String
  rfc                 String?
  direccion           String?
  telefono            String?
  country_code        String?               @default("52")
  email               String?
  contacto            String?
  is_active           Boolean               @default(true)
  legacy_client_id    Int?                  @unique
  organization_id     String
  created_at          DateTime              @default(now())
  updated_at          DateTime
  accounts_receivable accounts_receivable[]
  organizations       organizations         @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  flow_recoveries     flow_recoveries[]
  invoices            invoices[]
  projects            projects[]
  quotes              quotes[]
  recoveries          recoveries[]
  converted_from_prospect prospects?        @relation("ProspectToClient")

  @@index([is_active])
  @@index([legacy_client_id])
  @@index([organization_id])
  @@index([rfc])
}

model prospects {
  id                    String          @id @default(uuid())
  nombre                String
  rfc                   String?
  direccion             String?
  telefono              String?
  country_code          String?         @default("52")
  email                 String?
  contacto              String?
  status                ProspectStatus  @default(NEW)
  source                String?
  estimated_value       Decimal?
  probability           Int?
  expected_close_date   DateTime?
  notes                 String?
  assigned_to_id        String?
  converted_to_client_id String?       @unique
  converted_at          DateTime?
  organization_id       String
  created_at            DateTime        @default(now())
  updated_at            DateTime        @default(now())
  organizations         organizations   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  assigned_to           users?          @relation("ProspectAssignedTo", fields: [assigned_to_id], references: [id])
  converted_to_client   clients?        @relation("ProspectToClient", fields: [converted_to_client_id], references: [id])

  @@index([organization_id])
  @@index([status])
  @@index([assigned_to_id])
  @@index([converted_to_client_id])
  @@index([expected_close_date])
}

model comments {
  id              String   @id
  content         String
  task_id         String
  user_id         String
  organization_id String
  created_at      DateTime @default(now())
  tasks           tasks    @relation(fields: [task_id], references: [id], onDelete: Cascade)
  users           users    @relation(fields: [user_id], references: [id])

  @@index([organization_id])
  @@index([task_id])
}

model dispatch_attachments {
  id          String     @id
  dispatch_id String
  file_name   String
  file_url    String
  file_size   Int?
  mime_type   String?
  created_at  DateTime   @default(now())
  dispatches  dispatches @relation(fields: [dispatch_id], references: [id], onDelete: Cascade)

  @@index([dispatch_id])
}

model dispatches {
  id                   String                 @id
  content              String
  description          String?
  link                 String?
  urgency_level        UrgencyLevel           @default(NORMAL)
  status               DispatchStatus         @default(SENT)
  sender_id            String
  recipient_id         String
  organization_id      String
  task_id              String?                @unique
  due_date             DateTime?
  read_at              DateTime?
  in_progress_at       DateTime?
  resolved_at          DateTime?
  resolution_note      String?
  created_at           DateTime               @default(now())
  updated_at           DateTime
  dispatch_attachments dispatch_attachments[]
  organizations        organizations          @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  tasks                tasks?                 @relation(fields: [task_id], references: [id])
  sender               users                  @relation("DispatchSender", fields: [sender_id], references: [id], onDelete: Cascade)
  recipient            users                  @relation("DispatchRecipient", fields: [recipient_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([organization_id])
  @@index([recipient_id])
  @@index([sender_id])
  @@index([status])
  @@index([task_id])
  @@index([urgency_level])
}

model expenses {
  id              String        @id
  user_id         String
  project_id      String?
  category        String
  amount          Decimal
  currency        String        @default("USD")
  date            DateTime
  description     String
  receipt_url     String?
  status          ExpenseStatus @default(DRAFT)
  approved_by     String?
  approved_at     DateTime?
  reimbursed_at   DateTime?
  organization_id String
  created_at      DateTime      @default(now())
  updated_at      DateTime
  projects        projects?     @relation(fields: [project_id], references: [id])
  users           users         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([organization_id])
  @@index([project_id])
  @@index([status])
  @@index([user_id])
}

model fixed_costs {
  id                   String        @id
  nombre               String
  categoria            String
  monto                Decimal
  periodicidad         String
  dia_vencimiento      Int?
  is_active            Boolean       @default(true)
  ultimo_pago          DateTime?
  proximo_pago         DateTime?
  notas                String?
  legacy_fixed_cost_id Int?          @unique
  organization_id      String
  created_at           DateTime      @default(now())
  updated_at           DateTime
  organizations        organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([categoria])
  @@index([is_active])
  @@index([legacy_fixed_cost_id])
  @@index([organization_id])
  @@index([proximo_pago])
}

model flow_recoveries {
  id                      String        @id
  client_id               String
  periodo                 String
  monto_inicial           Decimal
  recuperaciones_reales   Decimal       @default(0)
  porcentaje_recuperado   Decimal       @default(0)
  notas                   String?
  metadata                Json?
  legacy_flow_recovery_id Int?          @unique
  organization_id         String
  created_at              DateTime      @default(now())
  updated_at              DateTime
  clients                 clients       @relation(fields: [client_id], references: [id])
  organizations           organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([legacy_flow_recovery_id])
  @@index([organization_id])
}

model invoices {
  id                String
  number            String
  client_id         String?
  amount            Decimal
  due_date          DateTime
  organization_id   String
  created_at        DateTime      @default(now())
  updated_at        DateTime
  cfdi_url          String?
  cfdi_uuid         String?
  currency          String        @default("MXN")
  documents         Json?
  issue_date        DateTime?
  legacy_invoice_id Int?          @unique
  payment_form      String?
  payment_method    String?
  pdf_url           String?
  subtotal          Decimal?
  tax               Decimal?
  total             Decimal?
  uso_cfdi          String?
  status            InvoiceStatus @default(DRAFT)
  clients           clients?      @relation(fields: [client_id], references: [id])
  organizations     organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([number, organization_id])
  @@index([legacy_invoice_id])
  @@index([organization_id])
  @@index([status])
}

model journal_entries {
  id              String          @id
  description     String
  date            DateTime
  reference       String?
  is_locked       Boolean         @default(false)
  organization_id String
  created_at      DateTime        @default(now())
  updated_at      DateTime
  organizations   organizations   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  journal_lines   journal_lines[]

  @@index([date])
  @@index([organization_id])
}

model journal_lines {
  id                                                 String          @id
  journal_entry_id                                   String
  amount                                             Decimal
  debit_account_id                                   String
  credit_account_id                                  String
  accounts_journal_lines_credit_account_idToaccounts accounts        @relation("journal_lines_credit_account_idToaccounts", fields: [credit_account_id], references: [id])
  accounts_journal_lines_debit_account_idToaccounts  accounts        @relation("journal_lines_debit_account_idToaccounts", fields: [debit_account_id], references: [id])
  journal_entries                                    journal_entries @relation(fields: [journal_entry_id], references: [id], onDelete: Cascade)

  @@index([credit_account_id])
  @@index([debit_account_id])
  @@index([journal_entry_id])
}

model organization_modules {
  id              String        @id
  organization_id String
  module_id       String
  is_enabled      Boolean       @default(true)
  created_at      DateTime      @default(now())
  updated_at      DateTime
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, module_id])
  @@index([module_id])
  @@index([organization_id])
}

model organizations {
  id                   String                 @id
  name                 String
  slug                 String                 @unique
  is_active            Boolean                @default(true)
  created_at           DateTime               @default(now())
  updated_at           DateTime
  logo_url             String?                // Organization logo (base64 or URL)
  logo_zoom            Float?                 @default(1.0) // Logo zoom/scale (0.5 - 2.0)
  primary_color        String?                // Primary brand color (hex)
  secondary_color      String?                // Secondary brand color (hex)
  accent_color         String?                // Accent brand color (hex)
  accounts             accounts[]
  accounts_payable     accounts_payable[]
  accounts_receivable  accounts_receivable[]
  api_keys             api_keys[]
  categories           categories[]
  clients              clients[]
  dispatches           dispatches[]
  fixed_costs          fixed_costs[]
  flow_recoveries      flow_recoveries[]
  invoices             invoices[]
  journal_entries      journal_entries[]
  organization_modules organization_modules[]
  payment_complements  payment_complements[]
  phases               phases[]
  projects             projects[]
  purchase_orders      purchase_orders[]
  quotes               quotes[]
  recoveries           recoveries[]
  requisitions         requisitions[]
  roles                roles[]
  suppliers            suppliers[]
  users                users[]
  webhooks             webhooks[]
  notifications        notifications[]
  prospects            prospects[]
}

model password_reset_tokens {
  id         String   @id
  token      String   @unique
  user_id    String
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token])
}

model payment_complements {
  id                           String            @id
  account_receivable_id        String?
  monto                        Decimal
  fecha_pago                   DateTime
  forma_pago                   String?
  referencia                   String?
  notas                        String?
  cfdi_uuid                    String?
  cfdi_url                     String?
  legacy_payment_complement_id Int?              @unique
  organization_id              String
  created_at                   DateTime          @default(now())
  updated_at                   DateTime
  account_payable_id           String?
  accounts_payable             accounts_payable? @relation(fields: [account_payable_id], references: [id], onDelete: Cascade)
  organizations                organizations     @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([account_payable_id])
  @@index([account_receivable_id])
  @@index([fecha_pago])
  @@index([legacy_payment_complement_id])
  @@index([organization_id])
}

model permissions {
  id                  String             @id
  resource            String
  action              String
  description         String?
  is_superadmin_only  Boolean            @default(false)
  created_at          DateTime           @default(now())
  updated_at          DateTime
  role_permissions    role_permissions[]

  @@unique([resource, action])
  @@index([is_superadmin_only])
}

model phases {
  id              String        @id
  name            String
  description     String?
  color           String?
  order           Int           @default(0)
  legacy_phase_id Int?          @unique
  organization_id String
  created_at      DateTime      @default(now())
  updated_at      DateTime
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  projects        projects[]

  @@index([legacy_phase_id])
  @@index([order])
  @@index([organization_id])
}

model projects {
  id                  String                @id
  name                String
  description         String?
  status              ProjectStatus         @default(PLANNING)
  start_date          DateTime?
  end_date            DateTime?
  owner_id            String?
  organization_id     String
  created_at          DateTime              @default(now())
  updated_at          DateTime
  deleted_at          DateTime?
  amount_with_tax     Decimal?
  amount_without_tax  Decimal?
  client_id           String?
  legacy_project_id   Int?                  @unique
  phase_id            String?
  ProjectOwners       ProjectOwners[]
  accounts_receivable accounts_receivable[]
  expenses            expenses[]
  clients             clients?              @relation(fields: [client_id], references: [id])
  organizations       organizations         @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  phases              phases?               @relation(fields: [phase_id], references: [id])
  purchase_orders     purchase_orders[]
  quotes              quotes[]
  recoveries          recoveries[]
  sprints             sprints[]
  tasks               tasks[]
  time_entries        time_entries[]
  users               users[]               @relation("ProjectMembers")

  @@index([client_id])
  @@index([legacy_project_id])
  @@index([organization_id])
  @@index([owner_id])
  @@index([phase_id])
}

model purchase_orders {
  id               String              @id
  folio            String              @unique
  description      String
  amount           Decimal             @db.Decimal(10, 2)
  includes_vat     Boolean             @default(false)
  subtotal         Decimal             @db.Decimal(10, 2)
  vat              Decimal             @db.Decimal(10, 2)
  total            Decimal             @db.Decimal(10, 2)
  comments         String?
  supplier_id      String?
  project_id       String?
  status           PurchaseOrderStatus @default(DRAFT)
  created_by_id    String
  authorized_by_id String?
  authorized_at    DateTime?
  min_payment_date DateTime
  max_payment_date DateTime
  pdf_url          String?
  organization_id  String
  created_at       DateTime            @default(now())
  updated_at       DateTime
  users            users?              @relation(fields: [authorized_by_id], references: [id])
  organizations    organizations       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  projects         projects?           @relation(fields: [project_id], references: [id])
  suppliers        suppliers?          @relation(fields: [supplier_id], references: [id])

  @@index([created_at])
  @@index([created_by_id])
  @@index([organization_id])
  @@index([project_id])
  @@index([status])
  @@index([supplier_id])
}

model quotes {
  id              String        @id
  project_id      String?
  client_id       String?
  numero          String
  descripcion     String?
  subtotal        Decimal
  iva             Decimal
  total           Decimal
  valido_hasta    DateTime?
  status          QuoteStatus   @default(DRAFT)
  notas           String?
  pdf_url         String?
  legacy_quote_id Int?          @unique
  organization_id String
  created_at      DateTime      @default(now())
  updated_at      DateTime
  clients         clients?      @relation(fields: [client_id], references: [id])
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  projects        projects?     @relation(fields: [project_id], references: [id])

  @@unique([numero, organization_id])
  @@index([client_id])
  @@index([legacy_quote_id])
  @@index([organization_id])
  @@index([project_id])
  @@index([status])
  @@index([valido_hasta])
}

model recoveries {
  id                 String        @id
  client_id          String
  project_id         String?
  descripcion        String
  monto_esperado     Decimal
  monto_recuperado   Decimal       @default(0)
  fecha_inicio       DateTime
  fecha_estimada     DateTime?
  fecha_recuperacion DateTime?
  status             String        @default("PENDIENTE")
  notas              String?
  legacy_recovery_id Int?          @unique
  organization_id    String
  created_at         DateTime      @default(now())
  updated_at         DateTime
  clients            clients       @relation(fields: [client_id], references: [id])
  organizations      organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  projects           projects?     @relation(fields: [project_id], references: [id])

  @@index([client_id])
  @@index([fecha_estimada])
  @@index([legacy_recovery_id])
  @@index([organization_id])
  @@index([project_id])
  @@index([status])
}

model requisitions {
  id                    String            @id
  supplier_id           String?
  descripcion           String
  monto                 Decimal
  fecha_solicitud       DateTime
  fecha_requerida       DateTime?
  status                RequisitionStatus @default(DRAFT)
  aprobado_por          String?
  fecha_aprobacion      DateTime?
  orden_compra          String?
  fecha_recepcion       DateTime?
  notas                 String?
  legacy_requisition_id Int?              @unique
  organization_id       String
  created_at            DateTime          @default(now())
  updated_at            DateTime
  organizations         organizations     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  suppliers             suppliers?        @relation(fields: [supplier_id], references: [id])

  @@index([fecha_requerida])
  @@index([fecha_solicitud])
  @@index([legacy_requisition_id])
  @@index([organization_id])
  @@index([status])
  @@index([supplier_id])
}

model role_permissions {
  role_id       String
  permission_id String
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
}

model roles {
  id               String             @id
  name             String
  description      String?
  is_system        Boolean            @default(false)
  level            Int                @default(1)
  category         String?
  organization_id  String
  created_at       DateTime           @default(now())
  updated_at       DateTime
  role_permissions role_permissions[]
  organizations    organizations      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  users            users[]

  @@unique([name, organization_id])
  @@index([level])
  @@index([organization_id])
}

model sessions {
  id             String   @id
  user_id        String
  refresh_token  String   @unique
  user_agent     String?
  ip_address     String?
  expires_at     DateTime
  is_valid       Boolean  @default(true)
  created_at     DateTime @default(now())
  last_active_at DateTime @default(now())

  @@index([refresh_token])
  @@index([user_id])
}

model sprints {
  id              String   @id
  name            String
  project_id      String
  start_date      DateTime
  end_date        DateTime
  goal            String?
  organization_id String
  projects        projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
  tasks           tasks[]
  users           users[]  @relation("SprintMembers")

  @@index([organization_id])
  @@index([project_id])
}

model suppliers {
  id                 String             @id
  run_proveedor      String?
  nombre             String
  rfc                String?
  direccion          String?
  telefono           String?
  country_code       String?            @default("52")
  email              String?
  contacto           String?
  datos_bancarios    String?
  is_active          Boolean            @default(true)
  legacy_supplier_id Int?               @unique
  organization_id    String
  created_at         DateTime           @default(now())
  updated_at         DateTime
  accounts_payable   accounts_payable[]
  purchase_orders    purchase_orders[]
  requisitions       requisitions[]
  organizations      organizations      @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([is_active])
  @@index([legacy_supplier_id])
  @@index([organization_id])
  @@index([rfc])
}

model tasks {
  id                 String         @id
  title              String
  description        String?
  status             TaskStatus     @default(TODO)
  priority           TaskPriority   @default(MEDIUM)
  project_id         String
  sprint_id          String?
  assignee_id        String?
  reporter_id        String
  position           Int            @default(0)
  due_date           DateTime?
  estimated_hours    Float?
  actual_hours       Float?
  organization_id    String
  created_at         DateTime       @default(now())
  updated_at         DateTime
  drive_link         String?
  source_dispatch_id String?        @unique
  attachments        attachments[]
  comments           comments[]
  dispatches         dispatches?
  projects           projects       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  sprints            sprints?       @relation(fields: [sprint_id], references: [id])
  time_entries       time_entries[]
  assignee           users?         @relation("TaskAssignee", fields: [assignee_id], references: [id])
  reporter           users          @relation("TaskReporter", fields: [reporter_id], references: [id])

  @@index([assignee_id])
  @@index([organization_id])
  @@index([project_id])
  @@index([source_dispatch_id])
  @@index([status])
}

model time_entries {
  id              String          @id
  user_id         String
  task_id         String?
  project_id      String?
  hours           Float
  date            DateTime
  description     String?
  status          TimeEntryStatus @default(DRAFT)
  approved_by     String?
  approved_at     DateTime?
  organization_id String
  created_at      DateTime        @default(now())
  updated_at      DateTime
  projects        projects?       @relation(fields: [project_id], references: [id])
  tasks           tasks?          @relation(fields: [task_id], references: [id])
  users           users           @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([organization_id])
  @@index([project_id])
  @@index([status])
  @@index([task_id])
  @@index([user_id])
}

model users {
  id                    String                  @id
  email                 String
  password              String
  first_name            String
  last_name             String
  is_active             Boolean                 @default(true)
  avatar_url            String?
  last_login_at         DateTime?
  organization_id       String?                 // CRITICAL: Nullable for SuperAdmin global
  role_id               String
  ubicacion             String?                 // E.g., R1, R2, R3, Taller
  created_at            DateTime                @default(now())
  updated_at            DateTime
  deleted_at            DateTime?
  firebase_uid          String?                 @unique
  legacy_user_id        Int?                    @unique
  api_keys              api_keys[]
  comments              comments[]
  expenses              expenses[]
  password_reset_tokens password_reset_tokens[]
  purchase_orders       purchase_orders[]
  time_entries          time_entries[]
  sent_dispatches       dispatches[]            @relation("DispatchSender")
  received_dispatches   dispatches[]            @relation("DispatchRecipient")
  organizations         organizations?          @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  roles                 roles                   @relation(fields: [role_id], references: [id])
  projects              projects[]              @relation("ProjectMembers")
  sprints               sprints[]               @relation("SprintMembers")
  assignedTasks         tasks[]                 @relation("TaskAssignee")
  reportedTasks         tasks[]                 @relation("TaskReporter")
  notifications         notifications[]
  assigned_prospects    prospects[]             @relation("ProspectAssignedTo")
  audit_logs            audit_logs[]

  @@unique([email, organization_id])
  @@index([email])
  @@index([firebase_uid])
  @@index([legacy_user_id])
  @@index([organization_id])
  @@index([role_id])
}

model webhooks {
  id              String        @id
  organization_id String
  url             String
  event           String
  secret          String?
  is_active       Boolean       @default(true)
  created_at      DateTime      @default(now())
  updated_at      DateTime
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([event])
  @@index([is_active])
  @@index([organization_id])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum DispatchStatus {
  SENT
  READ
  IN_PROGRESS
  RESOLVED
  CONVERTED_TO_TASK
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
